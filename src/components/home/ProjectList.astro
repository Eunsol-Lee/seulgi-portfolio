---
import { useTranslations, getLocalizedPath, type Lang } from '@i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = (await getCollection('projects', (entry) => entry.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="projects section" id="projects">
  <div class="container">
    <p class="section-label">{t('section.work')}</p>

    <ul class="projects__list">
      {projects.map((project, i) => (
        <li class="project-item reveal" data-index={String(i + 1).padStart(2, '0')}>
          <a
            href={getLocalizedPath(`/projects/${project.data.slug}`, lang)}
            class="project-item__link"
          >
            <span class="project-item__number">{String(i + 1).padStart(2, '0')}</span>
            <span class="project-item__title">{project.data.title}</span>
            <span class="project-item__tag">{project.data.category}</span>
            <span class="project-item__year">{project.data.year}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .projects__list {
    border-top: 1px solid var(--color-border);
  }

  .project-item {
    border-bottom: 1px solid var(--color-border);
  }

  .project-item__link {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-6);
    transition: opacity var(--duration-fast) ease;
  }

  .projects__list:hover .project-item:not(:hover) {
    opacity: 0.3;
  }

  .project-item:hover .project-item__link {
    opacity: 1;
  }

  .project-item__number {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-light);
    font-weight: 500;
    min-width: 2rem;
  }

  .project-item__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    transition: color var(--duration-fast) ease;
  }

  .project-item:hover .project-item__title {
    color: var(--color-accent-deep);
  }

  .project-item__tag {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    background-color: var(--color-bg-alt);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .project-item__year {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .project-item__link {
      grid-template-columns: auto 1fr auto;
      gap: var(--space-4);
    }

    .project-item__tag {
      display: none;
    }

    .project-item__title {
      font-size: var(--text-xl);
    }
  }

  @media (max-width: 480px) {
    .project-item__number {
      display: none;
    }

    .project-item__link {
      grid-template-columns: 1fr auto;
    }
  }
</style>
