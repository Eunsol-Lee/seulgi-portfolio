---
import SEOHead from '@components/global/SEOHead.astro';
import Nav from '@components/global/Nav.astro';
import Footer from '@components/global/Footer.astro';
import CustomCursor from '@components/global/CustomCursor.astro';
import '@styles/global.css';
import { getLangFromUrl, getAlternateUrl } from '@i18n/utils';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogImage, ogType } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const altUrl = getAlternateUrl(Astro.url);
const altLang = lang === 'ko' ? 'en' : 'ko';
---

<!doctype html>
<html lang={lang === 'ko' ? 'ko-KR' : 'en-US'}>
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      lang={lang}
      alternateUrl={altUrl}
      alternateLocale={altLang}
    />
  </head>
  <body>
    <CustomCursor />
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { initSmoothScroll } from '@scripts/smooth-scroll';
      import { initScrollReveals } from '@scripts/scroll-reveals';
      import { initHero } from '@scripts/hero-animations';
      import { initCursor } from '@scripts/cursor';

      // Initialize all modules
      initSmoothScroll();
      initScrollReveals();
      initHero();
      initCursor();
    </script>
  </body>
</html>
