---
import BaseLayout from './BaseLayout.astro';
import { useTranslations, getLocalizedPath, type Lang } from '@i18n/utils';

interface Props {
  title: string;
  subtitle: string;
  client: string;
  year: number;
  role: string;
  scope: string;
  category: string;
  lang: Lang;
  slug: string;
  color?: string;
  navPrev?: { title: string; slug: string };
  navNext?: { title: string; slug: string };
}

const {
  title, subtitle, client, year, role, scope,
  category, lang, slug, color, navPrev, navNext,
} = Astro.props;

const t = useTranslations(lang);
const pageTitle = `${title} — ${t('nav.logo')}`;
---

<BaseLayout title={pageTitle} description={subtitle} ogType="article">
  <article class="project">
    <!-- Hero -->
    <header class="project__hero section container">
      <a href={getLocalizedPath('/', lang) + '#projects'} class="project__back link-underline">
        {t('project.back')}
      </a>

      <span class="project__tag">{category}</span>
      <h1 class="project__title reveal">{title}</h1>
      <p class="project__subtitle reveal">{subtitle}</p>

      <div class="project__meta reveal">
        <div class="project__meta-item">
          <span class="project__meta-label">{t('project.label.client')}</span>
          <span class="project__meta-value">{client}</span>
        </div>
        <div class="project__meta-item">
          <span class="project__meta-label">{t('project.label.year')}</span>
          <span class="project__meta-value">{year}</span>
        </div>
        <div class="project__meta-item">
          <span class="project__meta-label">{t('project.label.role')}</span>
          <span class="project__meta-value">{role}</span>
        </div>
        <div class="project__meta-item">
          <span class="project__meta-label">{t('project.label.scope')}</span>
          <span class="project__meta-value">{scope}</span>
        </div>
      </div>
    </header>

    <!-- Cover placeholder -->
    <div class="project__cover container">
      <div class="project__cover-image" style={color ? `background-color: ${color}20` : ''}>
        <span class="project__cover-placeholder">{title}</span>
      </div>
    </div>

    <!-- Content (MDX body) -->
    <div class="project__body container">
      <slot />
    </div>

    <!-- Navigation -->
    <nav class="project__nav container">
      {navPrev && (
        <a href={getLocalizedPath(`/projects/${navPrev.slug}`, lang)} class="project__nav-link project__nav-prev">
          <span class="project__nav-direction">&#8592;</span>
          <span class="project__nav-title">{navPrev.title}</span>
        </a>
      )}
      <a href={getLocalizedPath('/', lang) + '#projects'} class="project__nav-all">
        {t('project.all')}
      </a>
      {navNext && (
        <a href={getLocalizedPath(`/projects/${navNext.slug}`, lang)} class="project__nav-link project__nav-next">
          <span class="project__nav-title">{navNext.title}</span>
          <span class="project__nav-direction">&#8594;</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .project__hero {
    padding-top: calc(var(--nav-height) + var(--space-16));
    text-align: center;
  }

  .project__back {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: inline-block;
    margin-bottom: var(--space-8);
  }

  .project__tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-accent-deep);
    background-color: var(--color-accent-soft);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-6);
  }

  .project__title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .project__subtitle {
    font-size: var(--text-lg);
    max-width: 50ch;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .project__meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    text-align: left;
  }

  .project__meta-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    margin-bottom: var(--space-2);
  }

  .project__meta-value {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .project__cover {
    padding-block: var(--space-12);
  }

  .project__cover-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .project__cover-placeholder {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-text-light);
    opacity: 0.3;
  }

  .project__body {
    max-width: 800px;
    padding-bottom: var(--space-24);
  }

  .project__body :global(h2) {
    font-size: var(--text-xl);
    color: var(--color-text);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .project__body :global(h2:first-child) {
    margin-top: 0;
  }

  .project__body :global(p) {
    font-size: var(--text-base);
    line-height: 1.9;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .project__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .project__nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
    max-width: 35%;
  }

  .project__nav-link:hover {
    color: var(--color-text);
  }

  .project__nav-direction {
    font-size: var(--text-lg);
    color: var(--color-accent);
  }

  .project__nav-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project__nav-all {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
  }

  .project__nav-all:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .project__meta {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .project__meta {
      grid-template-columns: 1fr;
    }

    .project__nav-title {
      display: none;
    }
  }
</style>
