---
import BaseLayout from './BaseLayout.astro';
import { useTranslations, getLocalizedPath, type Lang } from '@i18n/utils';

interface Props {
  title: string;
  subtitle: string;
  date: string;
  tag: string;
  lang: Lang;
  slug: string;
  pullquote?: string;
  navPrev?: { title: string; slug: string };
  navNext?: { title: string; slug: string };
}

const {
  title, subtitle, date, tag, lang, slug,
  pullquote, navPrev, navNext,
} = Astro.props;

const t = useTranslations(lang);
const pageTitle = `${title} — ${t('nav.logo')}`;
---

<BaseLayout title={pageTitle} description={subtitle} ogType="article">
  <article class="post">
    <header class="post__hero container">
      <a href={getLocalizedPath('/blog', lang)} class="post__back link-underline">
        {t('blog.back')}
      </a>

      <div class="post__meta">
        <time class="post__date">{date}</time>
        <span class="post__tag">{tag}</span>
      </div>

      <h1 class="post__title reveal">{title}</h1>
      <p class="post__subtitle reveal">{subtitle}</p>
    </header>

    <div class="post__body container">
      <hr class="post__divider" />
      <slot />

      {pullquote && (
        <blockquote class="post__pullquote">
          {pullquote}
        </blockquote>
      )}
    </div>

    <nav class="post__nav container">
      {navPrev ? (
        <a href={getLocalizedPath(`/blog/${navPrev.slug}`, lang)} class="post__nav-link post__nav-prev">
          <span>&#8592;</span>
          <span>{navPrev.title}</span>
        </a>
      ) : <div />}
      <a href={getLocalizedPath('/blog', lang)} class="post__nav-center">Journal</a>
      {navNext ? (
        <a href={getLocalizedPath(`/blog/${navNext.slug}`, lang)} class="post__nav-link post__nav-next">
          <span>{navNext.title}</span>
          <span>&#8594;</span>
        </a>
      ) : <div />}
    </nav>
  </article>
</BaseLayout>

<style>
  .post__hero {
    padding-top: calc(var(--nav-height) + var(--space-16));
    max-width: 720px;
  }

  .post__back {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: inline-block;
    margin-bottom: var(--space-8);
  }

  .post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .post__date {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    font-weight: 500;
  }

  .post__tag {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-accent-deep);
    background-color: var(--color-accent-soft);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .post__title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .post__subtitle {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .post__body {
    max-width: 680px;
    padding-block: var(--space-8) var(--space-24);
  }

  .post__divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .post__body :global(p) {
    font-size: var(--text-base);
    line-height: 2;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .post__body :global(h2) {
    font-size: var(--text-xl);
    color: var(--color-text);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .post__pullquote {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-accent-deep);
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-6);
    margin-block: var(--space-8);
    line-height: 1.6;
  }

  .post__nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
    max-width: 720px;
  }

  .post__nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--duration-fast) ease;
  }

  .post__nav-link:hover {
    color: var(--color-text);
  }

  .post__nav-prev {
    justify-self: start;
  }

  .post__nav-next {
    justify-self: end;
    text-align: right;
  }

  .post__nav-center {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
  }
</style>
